---
apiVersion: v1
kind: Secret
metadata:
  name: hoa-db-secret
  namespace: hoa
type: Opaque
stringData:
  # MariaDB bootstrap (consumed by the mariadb container)
  MARIADB_DATABASE: "wordpress"
  MARIADB_USER: "wordpress"
  MARIADB_PASSWORD: "{{ hoa_db_password }}"
  MARIADB_ROOT_PASSWORD: "{{ hoa_db_root_password }}"
  # WordPress DB connection (consumed by the wordpress container)
  WORDPRESS_DB_NAME: "wordpress"
  WORDPRESS_DB_USER: "wordpress"
  WORDPRESS_DB_PASSWORD: "{{ hoa_db_password }}"
